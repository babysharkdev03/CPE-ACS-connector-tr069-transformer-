config mgmt_srv 'mgmt_srv'
	option enable 'true'
	option url 'http://192.168.8.2:7547/'
	option alias_addressing 'true'
	option defaultactivenotificationthrottle '0'
	option retry_minimum_wait '5'
	option retry_multiplier '2000'
	option upgrades_managed 'false'
	option parameter_key ''
	option username 'admin'
	option password 'admin'

config settings 'settings'
	option debug 'false'
	option log_level 'info'
	option xml_indent 'true'
	option interface 'wwan'
	option bind '0.0.0.0'
	option port '7547'
	option ssl_auth 'false'
	option ssl_ca_cert_path '/etc/ssl/certs/ca-certificates.crt'
	option ssl_cn_verification 'true'
	option notif_polling_interval '2'
	option ipmode '4'
	option acs_subnets '0.0.0.0/0'
	option mock_mode '0'
	option bootstrap_done '0'
	option pending_reboot_event '0'

config periodic_inform 'periodic_inform'
	option enable 'true'
	option interval '300'
	option time '1970-01-01T00:00:00Z'

config conn_request 'conn_request'
	option auth 'None'
	option enable 'true'
	option url ''
	option username 'cpe'
	option password 'change-me'

config forced_inform_params
	option uid '1'
	option path 'Device.ManagementServer.ConnectionRequestURL'

config forced_inform_params
	option uid '2'
	option path 'Device.RootDataModelVersion'
